# ─────────────────────────────────────────────
# Nexus Frontend — Environment Variables
# Copy this file to .env.local and fill in the values.
# ─────────────────────────────────────────────

# Base URL of the Nexus backend API (no trailing slash)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# API version prefix used in all requests
NEXT_PUBLIC_API_VERSION=v1

# Public URL of this frontend app (used for canonical links, redirects)
NEXT_PUBLIC_NEXUS_URL=http://localhost:3000

# Wisemen Soft marketing site URL (used in footer / branding links)
NEXT_PUBLIC_WISEMENSOFT_URL=https://wisemensoft.com
